# 복사해서 리포 루트에 .env로 저장 (gitignore됨). 서버가 spring.config.import로 읽어감.

# Google OAuth (console.cloud.google.com → OAuth 클라이언트 ID(웹))
# 승인된 리디렉션 URI: http://localhost:8080/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT HS256 서명 키 — 32바이트 이상 랜덤 문자열
JWT_SECRET=

# (선택) 기본값이 로컬 docker compose 기준이라 보통 생략 가능
# DB_URL=jdbc:postgresql://localhost:5432/moa
# DB_USER=moa
# DB_PASSWORD=moa
# REDIS_HOST=localhost
# REDIS_PORT=6379
# FRONTEND_URL=http://localhost:3000
